<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="zuDdV;TtGEd6ze@SjX$t" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="8IB;i/_#5JUNy~e6MRtM"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace keypad4x4 {" line1="" line2="    let rows: DigitalPin[] = []" line3="    let cols: DigitalPin[] = []" line4="" line5="    let keys = [" line6="        [&quot;1&quot;, &quot;2&quot;, &quot;3&quot;, &quot;B&quot;]," line7="        [&quot;4&quot;, &quot;5&quot;, &quot;6&quot;, &quot;B&quot;]," line8="        [&quot;7&quot;, &quot;8&quot;, &quot;9&quot;, &quot;C&quot;]," line9="        [&quot;*&quot;, &quot;0&quot;, &quot;#&quot;, &quot;D&quot;]" line10="    ]" line11="" line12="    //% block=&quot;iniciar keypad linhas %r1 %r2 %r3 %r4 colunas %c1 %c2 %c3 %c4&quot;" line13="    export function init(" line14="        r1: DigitalPin, r2: DigitalPin, r3: DigitalPin, r4: DigitalPin," line15="        c1: DigitalPin, c2: DigitalPin, c3: DigitalPin, c4: DigitalPin" line16="    ): void {" line17="" line18="        rows = [r1, r2, r3, r4]" line19="        cols = [c1, c2, c3, c4]" line20="" line21="        for (let r of rows) {" line22="            pins.digitalWritePin(r, 1)" line23="        }" line24="" line25="        for (let c of cols) {" line26="            pins.setPull(c, PinPullMode.PullUp)" line27="        }" line28="    }" line29="" line30="    //% block=&quot;tecla pressionada&quot;" line31="    export function readKey(): string {" line32="" line33="        for (let i = 0; i &lt; 4; i++) {" line34="" line35="            pins.digitalWritePin(rows[i], 0)" line36="" line37="            for (let j = 0; j &lt; 4; j++) {" line38="" line39="                if (pins.digitalReadPin(cols[j]) == 0) {" line40="                    basic.pause(200)" line41="" line42="                    while (pins.digitalReadPin(cols[j]) == 0) { }" line43="" line44="                    pins.digitalWritePin(rows[i], 1)" line45="                    return keys[i][j]" line46="                }" line47="            }" line48="" line49="            pins.digitalWritePin(rows[i], 1)" line50="        }" line51="" line52="        return &quot;&quot;" line53="    }" line54="}" numlines="55"></mutation></block></statement></block></xml>